{
  "manifest_version": 3,
  "name": "IQinsyt",
  "version": "1.0.0",
  "description": "Neutral AI-powered research for sports and current events.",

  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "https://polymarket.com/*",
    "https://*.polymarket.com/*",
    "https://kalshi.com/*",
    "https://*.kalshi.com/*",
    "https://metaculus.com/*",
    "https://*.metaculus.com/*",
    "https://manifold.markets/*",
    "https://*.manifold.markets/*",
    "https://predictit.org/*",
    "https://*.predictit.org/*",
    "https://betfair.com/*",
    "https://*.betfair.com/*",
    "https://smarkets.com/*",
    "https://*.smarkets.com/*"
  ],

  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://polymarket.com/*",
        "https://*.polymarket.com/*",
        "https://kalshi.com/*",
        "https://*.kalshi.com/*",
        "https://metaculus.com/*",
        "https://*.metaculus.com/*",
        "https://manifold.markets/*",
        "https://*.manifold.markets/*",
        "https://predictit.org/*",
        "https://*.predictit.org/*",
        "https://betfair.com/*",
        "https://*.betfair.com/*",
        "https://smarkets.com/*",
        "https://*.smarkets.com/*"
      ],
      "js": ["src/content/content-script.ts"],
      "run_at": "document_idle"
    }
  ],

  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },

  "action": {
    "default_title": "Open IQinsyt"
  }
}
